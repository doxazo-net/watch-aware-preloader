<?php

/*
 * Watch-Aware Preloader settings + status page. MIT-licensed.
 * Reads the engine's status.json (read-only) and, in Task 4, renders the
 * settings form. No secrets are ever rendered here.
 */

$docroot = $docroot ?? ($_SERVER['DOCUMENT_ROOT'] ?? '/usr/local/emhttp');
require_once "{$docroot}/plugins/watch-aware-preloader/include/status.php";
require_once "{$docroot}/plugins/watch-aware-preloader/include/paths.php";

$wapStatusPath = wap_default_status_path();
$wapStatus     = wap_read_status($wapStatusPath);
// Last connection-test result (#36), persisted by `rc.preloadd test` so it
// survives the transient /update.php progress popup.
$wapLastTest   = wap_read_last_test(wap_default_last_test_path());

$wapCfg = \function_exists('parse_plugin_cfg') ? parse_plugin_cfg('watch-aware-preloader') : [];
// Declare $var explicitly: Unraid populates it in the page's including scope, but
// naming it global here guards against an empty CSRF token if the include ever
// happens inside a function scope.
global $var;
$wapCsrf = $var['csrf_token'] ?? '';
require_once "{$docroot}/plugins/watch-aware-preloader/include/secrets.php";
$wapKeySet = wap_api_key_is_set(wap_default_secret_path());
require_once "{$docroot}/plugins/watch-aware-preloader/include/pickers.php";
$wapPickers    = wap_read_pickers(wap_default_pickers_path());
$wapServerUrl  = (string) ($wapCfg['SERVER_URL'] ?? 'http://localhost:8096');
$wapConnected  = wap_pickers_fresh($wapPickers, $wapServerUrl);
// Current selections (csv of ids, or legacy names) for checkbox state.
$wapSelUsers   = array_filter(array_map('trim', explode(',', (string) ($wapCfg['USERS'] ?? ''))), static fn (string $s): bool => $s !== '');
$wapSelLibs    = array_filter(array_map('trim', explode(',', (string) ($wapCfg['LIBRARIES'] ?? ''))), static fn (string $s): bool => $s !== '');
// Preserve the current selection as a hidden scalar in the gate / empty states:
// no USERS[]/LIBRARIES[] checkbox is posted there, so presave would normalize the
// field to "" and silently clear a saved selection on any unrelated save.
$wapCurUsers   = implode(',', $wapSelUsers);
$wapCurLibs    = implode(',', $wapSelLibs);
// Auto-detected path-map rules for the read-only table (hoisted so the inline
// island below opens directly with the connect-gate check).
$wapMaps       = wap_picker_pathmaps($wapPickers);
$wapRules      = (\is_array($wapMaps['rules'] ?? null)) ? $wapMaps['rules'] : [];
// Signal tiers for the dial rows: [cfg-prefix, label]. Default enabled (checked)
// and max 0 when the cfg key is absent, preserving pre-dials behavior.
$wapTiers = [
    ['RESUME', 'Resume points'],
    ['NEXTUP', 'Next-up episodes'],
    ['RECENT', 'Recently added'],
];
?>

<table class="tablesorter shift ups">
<thead><tr><th>Watch-Aware Preloader - settings</th></tr></thead>
</table>

<?php
/*
 * Save via /update.php, which runs as ROOT - the only context that can write the
 * 0600-root FAT flash files. In one request it: runs the #include hook
 * (presave.php: writes secrets.toml and normalizes the settings), then writes the
 * .cfg from the posted fields (#file), then runs rc.preloadd render (#command).
 * The API key is posted as #api_key so /update.php excludes it from the .cfg
 * (fields prefixed with # are not written to the file).
 */
?>
<form markdown="false" name="wap_settings" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="csrf_token" value="<?= htmlspecialchars($wapCsrf) ?>">
<input type="hidden" name="#file" value="watch-aware-preloader/watch-aware-preloader.cfg">
<input type="hidden" name="#include" value="plugins/watch-aware-preloader/include/presave.php">
<input type="hidden" name="#command" value="/usr/local/emhttp/plugins/watch-aware-preloader/scripts/rc.preloadd">
<input type="hidden" name="#arg[1]" value="render">

<dl>
    <dt><label for="wap_server_type">Server type</label></dt>
    <dd>
        <select id="wap_server_type" name="SERVER_TYPE" size="1">
            <option value="emby"<?= (($wapCfg['SERVER_TYPE'] ?? 'emby') === 'emby') ? ' selected' : '' ?>>Emby</option>
        </select>
    </dd>
</dl>
<blockquote class="inline_help">Jellyfin support arrives in Phase 3.</blockquote>

<dl>
    <dt><label for="wap_server_url">Server URL</label></dt>
    <dd><input type="text" id="wap_server_url" name="SERVER_URL" value="<?= htmlspecialchars((string) ($wapCfg['SERVER_URL'] ?? 'http://localhost:8096')) ?>"></dd>
</dl>
<blockquote class="inline_help">Base URL of your Emby server, e.g. http://tower:8096</blockquote>

<dl>
    <dt>Users to preload</dt>
    <dd>
    <?php if (!$wapConnected) { ?>
        <em>Connect to a server to choose users: save the Server URL and API key above, then click <strong>Test connection</strong>.</em>
        <input type="hidden" name="USERS" value="<?= htmlspecialchars($wapCurUsers) ?>">
    <?php } elseif (($wapUsers = wap_picker_users($wapPickers)) === []) { ?>
        <em>The server returned no users.</em>
        <input type="hidden" name="USERS" value="<?= htmlspecialchars($wapCurUsers) ?>">
    <?php } else {
        foreach ($wapUsers as $u) {
            $id = (string) ($u['id'] ?? '');
            if ($id === '') {
                continue; // an entry with no id cannot be persisted (empties are dropped)
            }
            $nm = (string) ($u['name'] ?? $id);
            $checked = (\in_array($id, $wapSelUsers, true) || \in_array($nm, $wapSelUsers, true)) ? ' checked' : '';
            ?>
        <label style="display:block"><input type="checkbox" name="USERS[]" value="<?= htmlspecialchars($id) ?>"<?= $checked ?>> <?= htmlspecialchars($nm) ?></label>
    <?php }
        } ?>
    </dd>
</dl>
<blockquote class="inline_help">Users whose watch-state is preloaded. Leave all unchecked to include every user.</blockquote>

<dl>
    <dt>Libraries to scope</dt>
    <dd>
    <?php if (!$wapConnected) { ?>
        <em>Connect to a server to choose libraries.</em>
        <input type="hidden" name="LIBRARIES" value="<?= htmlspecialchars($wapCurLibs) ?>">
    <?php } elseif (($wapLibs = wap_picker_libraries($wapPickers)) === []) { ?>
        <em>The server returned no libraries.</em>
        <input type="hidden" name="LIBRARIES" value="<?= htmlspecialchars($wapCurLibs) ?>">
    <?php } else {
        foreach ($wapLibs as $l) {
            $id = (string) ($l['id'] ?? '');
            if ($id === '') {
                continue; // an entry with no id cannot be persisted (empties are dropped)
            }
            $nm = (string) ($l['name'] ?? $id);
            $checked = \in_array($id, $wapSelLibs, true) ? ' checked' : '';
            ?>
        <label style="display:block"><input type="checkbox" name="LIBRARIES[]" value="<?= htmlspecialchars($id) ?>"<?= $checked ?>> <?= htmlspecialchars($nm) ?></label>
    <?php }
        } ?>
    </dd>
</dl>
<blockquote class="inline_help">Only items in the checked libraries are preloaded. Leave all unchecked to include every library.</blockquote>

<dl>
    <dt>Signal tiers</dt>
    <dd>
    <?php foreach ($wapTiers as [$wapTk, $wapTlabel]) {
        // Match rc.preloadd's cfg_bool truthy set (1/true/yes/on) so the checkbox
        // reflects exactly what rc render will emit, even for a hand-edited .cfg.
        $wapTEn  = \in_array(strtolower((string) ($wapCfg["TIER_{$wapTk}_ENABLED"] ?? '1')), ['1', 'true', 'yes', 'on'], true);
        $wapTMax = (int) ($wapCfg["TIER_{$wapTk}_MAX"] ?? 0);
        ?>
        <label style="display:block">
            <input type="checkbox" name="TIER_<?= $wapTk ?>_ENABLED" value="1"<?= $wapTEn ? ' checked' : '' ?>>
            <?= htmlspecialchars($wapTlabel) ?>
            &nbsp; max items <input type="number" name="TIER_<?= $wapTk ?>_MAX" min="0" max="10000" step="1" value="<?= $wapTMax ?>" style="width:6em">
        </label>
    <?php } ?>
    </dd>
</dl>
<blockquote class="inline_help">Which watch-signals contribute to the preload set, and a per-user item cap for each (0 = no limit). Priority order is fixed; unchecking a tier skips it entirely.</blockquote>

<dl>
    <dt><label for="wap_ram_percent">RAM budget (percent)</label></dt>
    <dd><input type="number" id="wap_ram_percent" name="RAM_PERCENT" min="1" max="100" step="1" value="<?= (int) ($wapCfg['RAM_PERCENT'] ?? 50) ?>"></dd>
</dl>
<blockquote class="inline_help">Share of available RAM used as the preload budget.</blockquote>

<dl>
    <dt><label for="wap_target_seconds">Target seconds</label></dt>
    <dd><input type="number" id="wap_target_seconds" name="TARGET_SECONDS" min="1" step="1" value="<?= (int) ($wapCfg['TARGET_SECONDS'] ?? 20) ?>"></dd>
</dl>
<blockquote class="inline_help">Seconds of playback to keep warm (covers disk spin-up).</blockquote>

<dl>
    <dt>Detected path maps</dt>
    <dd>
    <?php if (!$wapConnected) { ?>
        <em>Connect and Test connection to auto-detect Docker bind-mount path maps.</em>
    <?php } elseif ($wapRules === []) { ?>
        <em>No explicit path maps detected; the Unraid share-name convention will be used.</em>
    <?php } else { ?>
        <table class="tablesorter"><thead><tr><th>From</th><th>To</th><th>Source</th></tr></thead><tbody>
        <?php foreach ($wapRules as $r) { ?>
            <tr><td><?= htmlspecialchars((string) ($r['from'] ?? '')) ?></td><td><?= htmlspecialchars((string) ($r['to'] ?? '')) ?></td><td><?= htmlspecialchars((string) ($r['source'] ?? '')) ?></td></tr>
        <?php } ?>
        </tbody></table>
        <?php if (!empty($wapMaps['unraid_unc_fallback'])) { ?>
        <blockquote class="inline_help">Plus the Unraid UNC / share-name convention for any unmatched <code>\\host\Share</code> or <code>/share/Share</code> path.</blockquote>
        <?php } ?>
    <?php } ?>
    </dd>
</dl>

<dl>
    <dt><label for="wap_path_maps">Advanced: manual path-map override</label></dt>
    <dd><input type="text" id="wap_path_maps" name="PATH_MAPS" value="<?= htmlspecialchars((string) ($wapCfg['PATH_MAPS'] ?? '')) ?>"></dd>
</dl>
<blockquote class="inline_help">Optional extra <code>from=&gt;to</code> pairs separated by semicolons; these override auto-detected rules. Usually leave blank.</blockquote>

<dl>
    <dt><label for="wap_cron_interval">Schedule interval (minutes)</label></dt>
    <dd><input type="number" id="wap_cron_interval" name="CRON_INTERVAL" min="1" max="59" step="1" value="<?= (int) ($wapCfg['CRON_INTERVAL'] ?? 15) ?>"></dd>
</dl>
<blockquote class="inline_help">How often the cron one-shot runs.</blockquote>

<dl>
    <dt><label for="wap_api_key">API key <?= $wapKeySet ? '(currently: set)' : '(currently: not set)' ?></label></dt>
    <dd><input type="password" id="wap_api_key" name="#api_key" autocomplete="new-password" placeholder="<?= $wapKeySet ? 'leave blank to keep the current key' : 'paste your Emby API key' ?>"></dd>
</dl>
<blockquote class="inline_help">Stored in secrets.toml, never in the settings file and never shown here. Leave blank to keep the current key; tick the box below to remove it.</blockquote>

<?php if ($wapKeySet) { ?>
<dl>
    <dt><label for="wap_clear_api_key">Clear API key</label></dt>
    <dd><input type="checkbox" id="wap_clear_api_key" name="#clear_api_key" value="1"> remove the stored key on save</dd>
</dl>
<?php } ?>

<dl>
    <dt><strong>Save</strong></dt>
    <dd><span><input type="submit" value="Apply"></span></dd>
</dl>
</form>

<form markdown="false" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#command" value="/usr/local/emhttp/plugins/watch-aware-preloader/scripts/rc.preloadd">
<input type="hidden" name="#arg[1]" value="test">
<input type="hidden" name="csrf_token" value="<?= htmlspecialchars($wapCsrf) ?>">
<dl>
    <dt><strong>Test connection</strong></dt>
    <dd><span><input type="submit" value="Test connection"></span></dd>
</dl>
</form>

<?php if ($wapLastTest !== null) {
    // Strip the message's own OK:/FAIL: prefix for display; the PASS/FAIL badge
    // already conveys it (and messages without a prefix, e.g. "No server URL
    // configured.", are left intact).
    $wapLtMsg = preg_replace('/^(?:OK|FAIL):\s*/i', '', (string) ($wapLastTest['message'] ?? ''));
    // Bound the displayed message: it is root-written and already escaped, but
    // truncating guards against an unexpectedly long value blowing out the panel.
    // Use mb_* so a cut never splits a UTF-8 char (which would make the following
    // htmlspecialchars warn and drop content), with a byte-based fallback.
    if ((\function_exists('mb_strlen') ? \mb_strlen($wapLtMsg, 'UTF-8') : \strlen($wapLtMsg)) > 300) {
        $wapLtMsg = (\function_exists('mb_substr') ? \mb_substr($wapLtMsg, 0, 300, 'UTF-8') : substr($wapLtMsg, 0, 300)) . '...';
    }
    ?>
<blockquote class="inline_help">
    Last connection test
    (<?= htmlspecialchars(wap_format_pacific((string) ($wapLastTest['tested_at'] ?? ''))) ?>):
    <strong><?= (($wapLastTest['ok'] ?? null) === true) ? 'PASS' : 'FAIL' ?></strong>
    - <?= htmlspecialchars((string) $wapLtMsg) ?>
</blockquote>
<?php } ?>

<form markdown="false" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#command" value="/usr/local/emhttp/plugins/watch-aware-preloader/scripts/rc.preloadd">
<input type="hidden" name="#arg[1]" value="run-now">
<input type="hidden" name="csrf_token" value="<?= htmlspecialchars($wapCsrf) ?>">
<dl>
    <dt><strong>Run now</strong></dt>
    <dd><span><input type="submit" value="Run now"></span></dd>
</dl>
</form>

<table class="tablesorter shift ups">
<thead><tr><th>Watch-Aware Preloader - last run</th></tr></thead>
</table>

<?php if ($wapStatus === null) { ?>
<p>No run recorded yet. The preloader runs on a schedule; check back after the next run, or use <strong>Run now</strong> once settings are saved.</p>
<?php } else { ?>
<dl>
    <dt>Last run</dt>
    <dd><?= htmlspecialchars(wap_format_pacific((string) ($wapStatus['last_run'] ?? ''))) ?></dd>

    <dt>Result</dt>
    <dd>
        <?php if (!empty($wapStatus['ok'])) { ?>
            OK
        <?php } else { ?>
            Error: <?= htmlspecialchars((string) ($wapStatus['error'] ?? 'unknown')) ?>
        <?php } ?>
        (mode: <?= htmlspecialchars((string) ($wapStatus['mode'] ?? '?')) ?>,
        <?= (int) ($wapStatus['duration_ms'] ?? 0) ?> ms)
    </dd>

    <dt>Warmed</dt>
    <dd>
        <?= (int) ($wapStatus['preloaded'] ?? 0) ?> preloaded,
        <?= (int) ($wapStatus['skipped'] ?? 0) ?> skipped,
        <?= (int) ($wapStatus['missing'] ?? 0) ?> missing;
        <?= number_format((float) ($wapStatus['bytes_warmed'] ?? 0) / 1048576, 1) ?> MiB
        of <?= number_format((float) ($wapStatus['budget_bytes'] ?? 0) / 1048576, 1) ?> MiB budget
    </dd>

    <?php if (!empty($wapStatus['by_tier']) && \is_array($wapStatus['by_tier'])) { ?>
    <dt>By tier</dt>
    <dd>
        <?php $parts = [];
        foreach ($wapStatus['by_tier'] as $tier => $n) {
            $parts[] = htmlspecialchars((string) $tier) . ': ' . (int) $n;
        }
        echo implode(', ', $parts); ?>
    </dd>
    <?php } ?>

    <?php if (!empty($wapStatus['by_user']) && \is_array($wapStatus['by_user'])) { ?>
    <dt>By user (UserID)</dt>
    <dd>
        <?php $parts = [];
        foreach ($wapStatus['by_user'] as $uid => $n) {
            $parts[] = htmlspecialchars((string) $uid) . ': ' . (int) $n;
        }
        echo implode(', ', $parts); ?>
    </dd>
    <?php } ?>
</dl>
<?php } ?>
