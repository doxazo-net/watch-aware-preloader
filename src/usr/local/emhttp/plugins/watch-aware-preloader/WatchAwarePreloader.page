<?php

/*
 * Watch-Aware Preloader settings + status page. MIT-licensed.
 * Reads the engine's status.json (read-only) and, in Task 4, renders the
 * settings form. No secrets are ever rendered here.
 */

$docroot = $docroot ?? ($_SERVER['DOCUMENT_ROOT'] ?? '/usr/local/emhttp');
require_once "{$docroot}/plugins/watch-aware-preloader/include/status.php";
require_once "{$docroot}/plugins/watch-aware-preloader/include/paths.php";

$wapStatusPath = wap_default_status_path();
$wapStatus     = wap_read_status($wapStatusPath);

$wapCfg = \function_exists('parse_plugin_cfg') ? parse_plugin_cfg('watch-aware-preloader') : [];
// Declare $var explicitly: Unraid populates it in the page's including scope, but
// naming it global here guards against an empty CSRF token if the include ever
// happens inside a function scope.
global $var;
$wapCsrf = $var['csrf_token'] ?? '';
require_once "{$docroot}/plugins/watch-aware-preloader/include/secrets.php";
$wapKeySet = wap_api_key_is_set(wap_default_secret_path());
?>

<table class="tablesorter shift ups">
<thead><tr><th>Watch-Aware Preloader - settings</th></tr></thead>
</table>

<form markdown="false" name="wap_settings" method="POST" action="/plugins/watch-aware-preloader/include/save-settings.php" target="progressFrame">
<input type="hidden" name="csrf_token" value="<?= htmlspecialchars($wapCsrf) ?>">

<dl>
    <dt><label for="wap_server_type">Server type</label></dt>
    <dd>
        <select id="wap_server_type" name="SERVER_TYPE" size="1">
            <option value="emby"<?= (($wapCfg['SERVER_TYPE'] ?? 'emby') === 'emby') ? ' selected' : '' ?>>Emby</option>
        </select>
    </dd>
</dl>
<blockquote class="inline_help">Jellyfin support arrives in Phase 3.</blockquote>

<dl>
    <dt><label for="wap_server_url">Server URL</label></dt>
    <dd><input type="text" id="wap_server_url" name="SERVER_URL" value="<?= htmlspecialchars((string) ($wapCfg['SERVER_URL'] ?? 'http://localhost:8096')) ?>"></dd>
</dl>
<blockquote class="inline_help">Base URL of your Emby server, e.g. http://tower:8096</blockquote>

<dl>
    <dt><label for="wap_users">Users</label></dt>
    <dd><input type="text" id="wap_users" name="USERS" value="<?= htmlspecialchars((string) ($wapCfg['USERS'] ?? '')) ?>"></dd>
</dl>
<blockquote class="inline_help">Comma-separated user names to preload for. Leave empty to include all users.</blockquote>

<dl>
    <dt><label for="wap_ram_percent">RAM budget (percent)</label></dt>
    <dd><input type="number" id="wap_ram_percent" name="RAM_PERCENT" min="1" max="100" step="1" value="<?= (int) ($wapCfg['RAM_PERCENT'] ?? 50) ?>"></dd>
</dl>
<blockquote class="inline_help">Share of available RAM used as the preload budget.</blockquote>

<dl>
    <dt><label for="wap_target_seconds">Target seconds</label></dt>
    <dd><input type="number" id="wap_target_seconds" name="TARGET_SECONDS" min="1" step="1" value="<?= (int) ($wapCfg['TARGET_SECONDS'] ?? 20) ?>"></dd>
</dl>
<blockquote class="inline_help">Seconds of playback to keep warm (covers disk spin-up).</blockquote>

<dl>
    <dt><label for="wap_path_maps">Path maps</label></dt>
    <dd><input type="text" id="wap_path_maps" name="PATH_MAPS" value="<?= htmlspecialchars((string) ($wapCfg['PATH_MAPS'] ?? '/share=>/mnt/user')) ?>"></dd>
</dl>
<blockquote class="inline_help">Map server paths to host paths as from=&gt;to pairs, separated by semicolons, e.g. /share=&gt;/mnt/user; /media=&gt;/mnt/user/media</blockquote>

<dl>
    <dt><label for="wap_cron_interval">Schedule interval (minutes)</label></dt>
    <dd><input type="number" id="wap_cron_interval" name="CRON_INTERVAL" min="1" max="59" step="1" value="<?= (int) ($wapCfg['CRON_INTERVAL'] ?? 15) ?>"></dd>
</dl>
<blockquote class="inline_help">How often the cron one-shot runs.</blockquote>

<dl>
    <dt><label for="wap_api_key">API key <?= $wapKeySet ? '(currently: set)' : '(currently: not set)' ?></label></dt>
    <dd><input type="password" id="wap_api_key" name="api_key" autocomplete="new-password" placeholder="<?= $wapKeySet ? 'leave blank to keep the current key' : 'paste your Emby API key' ?>"></dd>
</dl>
<blockquote class="inline_help">Stored in secrets.toml, never in the settings file and never shown here. Leave blank to keep the current key; tick the box below to remove it.</blockquote>

<?php if ($wapKeySet) { ?>
<dl>
    <dt><label for="wap_clear_api_key">Clear API key</label></dt>
    <dd><input type="checkbox" id="wap_clear_api_key" name="clear_api_key" value="1"> remove the stored key on save</dd>
</dl>
<?php } ?>

<dl>
    <dt><strong>Save</strong></dt>
    <dd><span><input type="submit" value="Apply"></span></dd>
</dl>
