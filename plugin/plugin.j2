<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN>

<!-- name= is the kebab IDENTIFIER, not a display label. Unraid's plugin manager
     seeds the status-cell DOM id from it (ShowPlugins.php: str_replace('.','-',name),
     which does NOT strip spaces) and resolves plugins/$name/ paths (icon, README)
     from it. A whitespace-free identifier is REQUIRED: a spaced name yields an id
     like "sid-Watch-Aware Preloader" that the client jQuery $('#'+id) reads as a
     descendant combinator, so the version-check spinner never resolves. The friendly
     "Watch-Aware Preloader" label is supplied separately by the packaged README.md
     (ShowPlugins.php renders plugins/$name/README.md as the Plugins-tab description,
     falling back to the bold name only when absent). -->
<!-- icon="hdd-o": hdd-o is the valid FontAwesome-4 hard-drive class Unraid
     ships. Solid fa-hdd is FA5+ and absent from Unraid's FA css, so it would
     render empty (leaving the Plugins-inventory row with no clickable webUI
     link). -->
<PLUGIN
  name="watch-aware-preloader"
  author="sydlexius"
  version="{{ env['PLUGIN_VERSION'] }}"
  pluginURL="https://github.com/sydlexius/watch-aware-preloader/releases/latest/download/watch-aware-preloader.plg"
  launch="Settings/WatchAwarePreloader"
  support="https://github.com/sydlexius/watch-aware-preloader"
  min="7.0.0"
  icon="hdd-o"
>

<CHANGES>
<![CDATA[
###{{ env['PLUGIN_VERSION'] }}###
{{ env['PLUGIN_CHANGELOG'] }}

For older releases, see https://github.com/sydlexius/watch-aware-preloader/releases
]]>
</CHANGES>

<FILE Name="/boot/config/plugins/watch-aware-preloader/watch-aware-preloader-{{ env['PLUGIN_VERSION'] }}-noarch-1.txz">
<URL>https://github.com/sydlexius/watch-aware-preloader/releases/download/{{ env['PLUGIN_VERSION'] }}/watch-aware-preloader-{{ env['PLUGIN_VERSION'] }}-noarch-1.txz</URL>
<SHA256>{{ env['PLUGIN_CHECKSUM'] }}</SHA256>
</FILE>

<!-- install script (runs on install AND on each Unraid boot) -->
<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
upgradepkg --install-new /boot/config/plugins/watch-aware-preloader/watch-aware-preloader-{{ env['PLUGIN_VERSION'] }}-noarch-1.txz

# remove superseded packages
for f in /boot/config/plugins/watch-aware-preloader/watch-aware-preloader-*.txz; do
  [ -e "$f" ] || continue
  case "$f" in
    */watch-aware-preloader-{{ env['PLUGIN_VERSION'] }}-noarch-1.txz) ;;
    *) rm -f "$f" ;;
  esac
done

if ! bash /usr/local/emhttp/plugins/watch-aware-preloader/scripts/rc.preloadd install; then
  echo "ERROR: watch-aware-preloader install (seed/cron) failed" >&2
  exit 1
fi

echo ""
echo "----------------------------------------------------"
echo " watch-aware-preloader has been installed."
echo " Version: {{ env['PLUGIN_VERSION'] }}"
echo " Set your server URL + API key, then it runs every 15 min."
echo "----------------------------------------------------"
echo ""
]]>
</INLINE>
</FILE>

<!-- remove script: stop cron + runtime; remove cached .txz but PRESERVE flash config/secrets -->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
bash /usr/local/emhttp/plugins/watch-aware-preloader/scripts/rc.preloadd remove || echo "WARN: rc.preloadd remove reported an error; continuing uninstall" >&2
removepkg watch-aware-preloader
rm -rf /usr/local/emhttp/plugins/watch-aware-preloader
rm -f /boot/config/plugins/watch-aware-preloader/watch-aware-preloader-*.txz
# NOTE: /boot/config/plugins/watch-aware-preloader (config.toml, secrets.toml) is
# intentionally preserved so a reinstall keeps settings. Delete it by hand to purge.
]]>
</INLINE>
</FILE>

</PLUGIN>
