{
    "name": "sydlexius/watch-aware-preloader",
    "description": "PHP dev tooling for the watch-aware-preloader Unraid plugin settings page",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.0"
    },
    "scripts": {
        "lint": "phpstan analyse --no-progress",
        "check": "php-cs-fixer fix --dry-run --diff",
        "fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.1"
        }
    }
}
